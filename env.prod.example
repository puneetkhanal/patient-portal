# Application
NODE_ENV=production
PORT=3000
APP_NAME=Patient Portal
APP_URL=https://your-domain.example

# Database
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/?appName=APP
DB_NAME=patient_portal

# Authentication
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d

# Optional initial admin seed.
# Set these only for first deployment, then rotate/remove after creating real users.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
ADMIN_MUST_CHANGE_PASSWORD=true

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/app/uploads
