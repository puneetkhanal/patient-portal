# Backend Dockerfile
FROM node:24-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --only=production
RUN npm install tsx typescript @types/node @types/express @types/cors

# Copy server source
COPY server ./server
COPY tsconfig.server.json ./

# Expose port
EXPOSE 3001

# Start the server
CMD ["npx", "tsx", "server/index.ts"]

